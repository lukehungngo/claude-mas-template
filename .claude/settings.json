{
  "permissions": {
    "allow": [
      "Read:*",
      "Write:*",
      "Edit:*",
      "Bash:*",
      "Glob:*",
      "Grep:*",
      "Agent:*",
      "WebSearch",
      "WebFetch:*",
      "Skill:*",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "NotebookEdit:*",
      "SendMessage:*"
    ],
    "deny": [
      "Read:.env*",
      "Bash:sudo*",
      "Bash:rm -rf /*",
      "Bash:git push --force*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-dispatch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-stop-gate.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
